FROM postgres:14.12

# Build argument for which database this image is for
ARG DATABASE_NAME=solar_panel_large

# Set PostgreSQL credentials
ENV POSTGRES_USER=root
ENV POSTGRES_PASSWORD=123123

# Copy the shared initialization script
COPY environment/init-db.sh /docker-entrypoint-initdb.d/init-db.sh

# Set permissions
RUN chmod +x /docker-entrypoint-initdb.d/init-db.sh && \
    mkdir -p /docker-entrypoint-initdb.d/db_assets && \
    chmod 755 /docker-entrypoint-initdb.d/db_assets && \
    echo "[Dockerfile] Built for DATABASE: ${DATABASE_NAME}"
WORKDIR /docker-entrypoint-initdb.d

# Health check: verify PostgreSQL is running
HEALTHCHECK --interval=10s --timeout=5s --start-period=60s --retries=30 \
    CMD pg_isready -U ${POSTGRES_USER} || exit 1
