# BIRD-Interact-ADK Configuration
# Copy this to .env and fill in your values

# ── LLM ──
# Set the API key for your LLM provider (used by LiteLlm)
# See https://docs.litellm.ai/docs/providers for supported providers
ANTHROPIC_API_KEY=sk-ant-...        # for anthropic/claude-*
# OPENAI_API_KEY=sk-...             # for openai/gpt-*

# ── Models ──
# LiteLlm model format: provider/model-name
# Examples: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, ollama_chat/llama3
SYSTEM_AGENT_MODEL=anthropic/claude-sonnet-4-20250514
USER_SIM_MODEL=anthropic/claude-haiku-4-5-20251001

# ── Dataset ──
# Options: "lite" (300 tasks, 18 DBs) or "full" (600 tasks, 26 DBs)
DATASET=lite

# ── PostgreSQL ──
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=root
PG_PASSWORD=123123

# ── Service Ports ──
SYSTEM_AGENT_PORT=6000
USER_SIM_PORT=6001
DB_ENV_PORT=6002

# ── Budget / Turns ──
# a-interact: budget = 6 + 2*ambiguities + 2*patience (per task)
# c-interact: max_turns = ambiguities + patience (per task)
PATIENCE=3
